   <string notr="true">/* HEADER */
QWidget#header {
    background-color: #009688;
    color: white;
}

QPushButton {
    border: none;
    padding: 6px 15px;
    font-weight: bold;
    color: white;
}

QPushButton:hover {
    background-color: #00796B;
}

/* TITLE */
QLabel#mainTitle {
    font-size: 28px;
    color: #009688;
    font-weight: bold;
}

/* TABLE */
QTableWidget {
    background-color: #ffffff;
    border-radius: 10px;
    border: 1px solid #dfe6e9;
    font-size: 14px;
}

/* HEADER TABLE */
QHeaderView::section {
    background-color: #E0F2F1;
    font-weight: bold;
    padding: 8px;
    border: none;
    border-bottom: 2px solid #80CBC4;
}

/* ROW */
QTableWidget::item {
    padding: 10px;
    border-bottom: 1px solid #f1f1f1;
}

/* SELECT */
QTableWidget::item:selected {
    background-color: #009688;
    color: white;
}</string>
