              <property name="styleSheet">
               <string notr="true">/* ===== BACKGROUND ===== */
QWidget#centralwidget {
    background-color: #F5FAFF;
}

/* ===== HEADER ===== */
#wgt_Header {
    background-color: #4FC3F7;
    border-bottom: 2px solid #0288D1;
}

/* Button trên header */
#wgt_Header QPushButton {
    color: #2C3E50;
    background: transparent;
    padding: 6px 15px;
    border-radius: 6px;
}

#wgt_Header QPushButton:hover {
    background-color: #0288D1;
    color: white;
}

/* ===== TITLE ===== */
#lbl_TieuDe {
    color: #0288D1;
    font-size: 32px;
    font-weight: bold;
}

/* ===== PANEL (khung trắng giữa) ===== */
#wgt_LichSuPanel {
    background-color: white;
    border-radius: 12px;
    border: 1px solid #D6EAF8;
}

/* ===== TABLE ===== */
QTableWidget {
    background-color: white;
    alternate-background-color: #F0F8FF;
    border: none;
    border-radius: 10px;
    color: #2C3E50;
}

/* Header bảng */
QHeaderView::section {
    background-color: #E1F5FE;
    border-bottom: 2px solid #4FC3F7;
    font-weight: bold;
    padding: 10px;
}

/* Row */
QTableWidget::item {
    padding: 10px;
    border-bottom: 1px solid #EAF2F8;
}

/* Select */
QTableWidget::item:selected {
    background-color: #4FC3F7;
    color: white;
}</string>
